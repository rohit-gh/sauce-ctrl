{
  "name": "sauce-ctrl",
  "version": "0.1.0",
  "description": "A browser-based Git GUI client — Git, but pleasant.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "bun --bun nuxt build",
    "dev": "bun --bun nuxt dev",
    "generate": "bun --bun nuxt generate",
    "preview": "bun --bun nuxt preview",
    "start": "bun --bun .output/server/index.mjs",
    "build:appimage": "bash scripts/build-appimage.sh",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource/anonymous-pro": "^5.2.8",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "devDependencies": {
    "@vite-pwa/nuxt": "^1.1.1"
  }
}
