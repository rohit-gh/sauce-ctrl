# SauceControl environment variables
#
# Copy this file to .env and adjust as needed.
# Most variables are optional — defaults work for local development.
#
#   cp .env.example .env

# =============================================================================
# SauceControl
# =============================================================================

# Port for the interactive terminal WebSocket server.
# Runs as a separate Bun child process (server/terminal-server.ts).
# The Nuxt client reads this via runtimeConfig.public.wsPort.
SAUCE_WS_PORT=3009

# =============================================================================
# Nuxt / Nitro (optional)
# =============================================================================

# HTTP port for the Nuxt dev server and Nitro API (default: 3000, auto-increments if busy)
# PORT=3000

# Bind host (default: localhost)
# HOST=localhost

# Bypass the "another Nuxt dev server is running" lock during development
# NUXT_IGNORE_LOCK=1

# =============================================================================
# Runtime (informational — usually inherited from the shell)
# =============================================================================

# Required by Bun runtime. SauceControl will not work under plain Node.
# Use: bun run dev   (script runs bun --bun nuxt dev)

# User home — SQLite DB lives at ~/.sauce-ctrl/sauce-ctrl.sqlite
# HOME=/home/you

# Default shell for PTY sessions (server/utils/pty.ts)
# SHELL=/bin/bash

# =============================================================================
# GitHub CLI (optional)
# =============================================================================

# gh auth is preferred (in-app GitHub Setup modal runs `gh auth login`).
# Token may be cached in SQLite settings after successful auth.
# GH_TOKEN=

# =============================================================================
# Set internally by SauceControl (do not usually configure)
# =============================================================================

# GIT_TERMINAL_PROMPT=0    # prevents git from prompting in API handlers
# GH_PROMPT_DISABLED=1     # used during gh status checks
